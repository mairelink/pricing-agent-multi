{
  "$schema": "https://opencode.ai/config.json",
  "model": "ai-gateway/anthropic/claude-sonnet-4-6",
  "mcp": {
    "confluence": {
      "type": "local",
      "command": ["bash", "./mcp-servers/confluence/confluence-mcp-server.sh"],
      "environment": {
        "CONFLUENCE_URL": "{env:CONFLUENCE_URL}",
        "CONFLUENCE_USER": "{env:CONFLUENCE_USER}",
        "CONFLUENCE_TOKEN": "{env:CONFLUENCE_TOKEN}",
        "CONFLUENCE_SPACE": "{env:CONFLUENCE_SPACE}"
      }
    },
    "jira": {
      "type": "local",
      "command": ["bash", "./mcp-servers/jira/jira-mcp-server.sh"],
      "environment": {
        "JIRA_URL": "{env:JIRA_URL}",
        "JIRA_USER": "{env:JIRA_USER}",
        "JIRA_TOKEN": "{env:JIRA_TOKEN}",
        "JIRA_PROJECT": "{env:JIRA_PROJECT}"
      }
    },
    "github": {
      "type": "local",
      "command": ["bash", "./mcp-servers/github/github-mcp-server.sh", "--org", "kramphub", "--org", "krampcom"],
      "environment": {
        "GITHUB_TOKEN": "{env:GITHUB_TOKEN}"
      }
    }
  }
}
